\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{hcmus_beamer}[2026/04/18 HCMUS Beamer Style - V-Pop Revenue]
\RequirePackage{tikz}

% --- 1. FONT CONFIGURATION (XeLaTeX) ---
\RequirePackage{fontspec}
\IfFontExistsTF{Fira Sans}{%
    \setsansfont{Fira Sans}[
        BoldFont       = {Fira Sans Bold},
        ItalicFont     = {Fira Sans Italic},
        BoldItalicFont = {Fira Sans Bold Italic}
    ]%
}{}
\IfFontExistsTF{Fira Mono}{%
    \setmonofont{Fira Mono}[Scale=0.85]%
}{}

% --- 2. THEME ---
\usetheme{Madrid}
\usecolortheme{beaver}

% --- 3. CUSTOM COLORS (navy / coral / ice blue) ---
\definecolor{navyPrimary}{HTML}{1E2761}
\definecolor{coralAccent}{HTML}{F96167}
\definecolor{iceBlue}{HTML}{CADCFC}
\definecolor{darkred}{HTML}{8B0000}

\setbeamercolor{structure}{fg=navyPrimary}
\setbeamercolor{palette primary}{bg=navyPrimary, fg=white}
\setbeamercolor{palette secondary}{bg=iceBlue, fg=navyPrimary}
\setbeamercolor{palette tertiary}{bg=navyPrimary!80, fg=white}
\setbeamercolor{palette quaternary}{bg=navyPrimary, fg=white}
\setbeamercolor{frametitle}{bg=navyPrimary!10, fg=navyPrimary}
\setbeamercolor{title}{fg=navyPrimary}
\setbeamercolor{block title}{bg=navyPrimary, fg=white}
\setbeamercolor{block body}{bg=iceBlue!20}
\setbeamercolor{block title alerted}{bg=coralAccent, fg=white}
\setbeamercolor{block body alerted}{bg=coralAccent!10}
\setbeamercolor{block title example}{bg=navyPrimary!60, fg=white}
\setbeamercolor{block body example}{bg=iceBlue!15}
\setbeamercolor{item}{fg=navyPrimary}
\setbeamercolor{subitem}{fg=coralAccent}

% --- 4. FONT THEME ---
\usefonttheme{professionalfonts}
\usefonttheme[onlymath]{serif}

% --- 5. UTILITIES ---
\RequirePackage{graphicx}
\RequirePackage{booktabs}
\RequirePackage{amsmath, amssymb}
\RequirePackage{caption}
\captionsetup{font=scriptsize, labelfont={bf}}

% --- 6. NAVIGATION ---
\setbeamertemplate{navigation symbols}{}

% --- 7. SECTION DIVIDER PAGES (auto) ---
\AtBeginSection[]{%
    \begin{frame}[plain, noframenumbering]
        \centering
        \vfill
        {\Large \textcolor{navyPrimary}{\secname}}
        \vspace{0.3em}

        \textcolor{coralAccent}{\rule{4cm}{1.5pt}}
        \vfill
    \end{frame}
}

% --- 8. HCMUS LOGO IN HEADER ---
\addtobeamertemplate{headline}{}{%
    \begin{tikzpicture}[remember picture,overlay]
        \node[anchor=north west, inner sep=0pt]
            at (current page.north west) [xshift=0.2cm, yshift=-0.1cm] {
            \includegraphics[height=0.7cm]{hcmus_logo}
        };
    \end{tikzpicture}
}

\endinput
