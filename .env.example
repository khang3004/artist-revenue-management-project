# PostgreSQL Configuration
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=artist_revenue_db
POSTGRES_PORT=5432

# pgAdmin Configuration
PGADMIN_DEFAULT_EMAIL=admin@admin.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050

# Streamlit Configuration
STREAMLIT_PORT=8501

# Database Connection String
# Database SSL Mode (require for Neon, disable for local)
DB_SSL_MODE=disable

# Database Connection String
# For Local Docker: postgresql://postgres:postgres@postgres:5432/artist_revenue_db
# For Neon Cloud: postgresql://user:password@neon-host/db?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/artist_revenue_db

MB_APP_NAME=artist-revenue-etl
MB_APP_VERSION=1.0
MB_CONTACT=your@email.com
